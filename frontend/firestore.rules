rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── General fallback: authenticated reads/writes ──
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── Events: public reads, auth writes ──
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;

      // Pending Donations subcollection
      // Users can create them. Organizers/Admins can read & update them.
      match /pendingDonations/{pendingId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if false;
      }

      // Donations subcollection — WRITE-ONCE via Admin SDK only.
      // Client-side writes are blocked; server routes use Admin SDK which bypasses rules.
      match /donations/{donationId} {
        allow read: if request.auth != null;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── Users: owners only ──
    match /users/{userId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      // User donation history — read-only from client, written by Admin SDK.
      match /donations/{donationId} {
        allow read:   if request.auth != null && request.auth.uid == userId;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

  }
}
