rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── General fallback: deny by default ──
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Events ──
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.organizerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.organizerId == request.auth.uid;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
      match /volunteers/{volunteerId} {
        allow read, write: if request.auth != null;
      }
      match /goodsPledges/{pledgeId} {
        allow read, write: if request.auth != null;
      }

      // Pending Donations subcollection
      match /pendingDonations/{pendingId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null && get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
        allow delete: if false;
      }

      // Donations subcollection — WRITE-ONCE via Admin SDK only.
      match /donations/{donationId} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }
    }

    // ── Users ──
    match /users/{userId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      match /registrations/{regId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User donation history — read-only from client
      match /donations/{donationId} {
        allow read:   if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if false;
      }
    }

    // ── Promotions ──
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /promotion_logs/{logId} {
      allow read, write: if request.auth != null;
    }

  }
}
